# vcpkg-harbor Configuration
# Copy this file to .env and modify as needed

# Server Settings
VCPKG_SERVER_HOST=0.0.0.0
VCPKG_SERVER_PORT=15151
VCPKG_SERVER_WORKERS=4
VCPKG_SERVER_RELOAD=false
VCPKG_SERVER_READ_ONLY=false
VCPKG_SERVER_WRITE_ONLY=false

# Storage Settings
# Options: filesystem, minio, s3, azure, gcs
VCPKG_STORAGE_TYPE=filesystem
VCPKG_STORAGE_PATH=./cache

# MinIO Settings (when VCPKG_STORAGE_TYPE=minio)
VCPKG_MINIO_ENDPOINT=localhost:9000
VCPKG_MINIO_ACCESS_KEY=minioadmin
VCPKG_MINIO_SECRET_KEY=minioadmin
VCPKG_MINIO_BUCKET=vcpkg-harbor
VCPKG_MINIO_SECURE=false

# AWS S3 Settings (when VCPKG_STORAGE_TYPE=s3)
# VCPKG_S3_BUCKET=vcpkg-harbor
# VCPKG_S3_REGION=us-east-1
# VCPKG_S3_ACCESS_KEY_ID=
# VCPKG_S3_SECRET_ACCESS_KEY=
# VCPKG_S3_ENDPOINT_URL=

# Azure Settings (when VCPKG_STORAGE_TYPE=azure)
# VCPKG_AZURE_CONNECTION_STRING=
# VCPKG_AZURE_ACCOUNT_NAME=
# VCPKG_AZURE_ACCOUNT_KEY=
# VCPKG_AZURE_CONTAINER=vcpkg-harbor

# GCS Settings (when VCPKG_STORAGE_TYPE=gcs)
# VCPKG_GCS_BUCKET=vcpkg-harbor
# VCPKG_GCS_PROJECT=
# VCPKG_GCS_CREDENTIALS_FILE=

# Logging Settings
VCPKG_LOG_LEVEL=INFO
VCPKG_LOG_JSON=false
VCPKG_LOG_FILE=logs/vcpkg-harbor.log
VCPKG_LOG_RETENTION_DAYS=30

# Authentication Settings
VCPKG_AUTH_ENABLED=false
# Options: none, basic, token
VCPKG_AUTH_TYPE=none
# For token auth:
# VCPKG_AUTH_TOKEN=your-secret-token
# For basic auth (comma-separated user:pass pairs):
# VCPKG_AUTH_BASIC_USERS=admin:password,user:pass

# Metrics Settings
VCPKG_METRICS_ENABLED=true
VCPKG_METRICS_PATH=/metrics

# Dashboard Settings
VCPKG_DASHBOARD_ENABLED=true
VCPKG_DASHBOARD_PATH=/
